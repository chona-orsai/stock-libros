# Supabase — copiá estos valores desde Settings → API en tu proyecto
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Solo para scripts locales (NO usar prefijo NEXT_PUBLIC_)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Solo para npm run setup-db (Settings → Database → Connection string)
SUPABASE_DB_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Solo para npm run create-admins
ADMIN_EMAILS=admin1@example.com,admin2@example.com
ADMIN_INITIAL_PASSWORD=cambiar-esta-contraseña
